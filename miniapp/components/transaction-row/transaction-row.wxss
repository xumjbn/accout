.tx-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 20rpx;
}

.tx-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.tx-note {
  font-size: 30rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tx-category {
  font-size: 24rpx;
  color: #6B7280;
}

.tx-source {
  width: 22rpx;
  height: 22rpx;
}

.tx-amount {
  font-size: 30rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
}

.tx-expense {
  color: #111827;
}

.tx-income {
  color: #10B981;
}
