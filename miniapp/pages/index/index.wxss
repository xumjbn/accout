.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F3F4F6;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #E5E7EB;
}

.search-input {
  height: 64rpx;
  background: #F3F4F6;
  border-radius: 32rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

/* 提醒条 */
.alert-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
}

.alert-warn {
  background: #FEF3C7;
  color: #92400E;
}

.alert-over {
  background: #FEE2E2;
  color: #991B1B;
}

.alert-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-title {
  font-size: 26rpx;
  font-weight: 600;
}

.alert-msg {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.alert-close {
  padding: 8rpx 16rpx;
  font-size: 28rpx;
  opacity: 0.5;
}

/* 内容 */
.content {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #9CA3AF;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 16rpx;
  color: #6B7280;
}

.empty-desc {
  font-size: 26rpx;
  margin-top: 8rpx;
}

/* 日期分组 */
.day-group {
  margin-bottom: 20rpx;
}

.day-header {
  padding: 16rpx 0 8rpx;
}

.day-title {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.tx-item {
  background: #fff;
  padding: 0 24rpx;
  border-radius: 12rpx;
}

.tx-item + .tx-item {
  margin-top: 2rpx;
  border-radius: 12rpx;
}

.bottom-spacer {
  height: 140rpx;
}

/* 语音按钮 */
.voice-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #2563EB;
  color: #fff;
  padding: 24rpx 56rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.4);
  font-size: 30rpx;
  font-weight: 600;
  z-index: 100;
}

.voice-btn-icon {
  font-size: 36rpx;
}

/* 顶部按钮 */
.top-btns {
  display: none; /* 使用页面自带的 navigation 导航栏 */
}
