.page {
  padding: 24rpx;
  background: #F3F4F6;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.type-toggle {
  display: flex;
  background: #F3F4F6;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.type-option.active {
  background: #2563EB;
  color: #fff;
}

.field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.field-label {
  font-size: 28rpx;
  color: #6B7280;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
}

.money-input {
  font-size: 48rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.picker-value {
  font-size: 28rpx;
  color: #111827;
}

.field-divider {
  height: 1rpx;
  background: #F3F4F6;
}

.save-btn {
  background: #2563EB;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.save-btn.disabled {
  opacity: 0.4;
}
