/* 全局样式 */
page {
  --color-primary: #4E6EF5;
  --color-primary-light: #7A5AF8;
  --grad-brand: linear-gradient(135deg, #4E6EF5 0%, #7A5AF8 100%);
  --color-bg: #F4F5FB;
  --color-surface: #FFFFFF;
  --color-text: #1B1F2C;
  --color-text-secondary: #6B7280;
  --color-text-tertiary: #9CA3AF;
  --color-separator: #ECEEF5;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --radius-card: 24rpx;
  --shadow-card: 0 6rpx 20rpx rgba(38, 48, 92, 0.06);

  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 14px;
  color: var(--color-text);
  /* 顶部淡靛晕染，向下过渡到浅灰蓝 */
  background: linear-gradient(180deg, #E9EDFF 0%, #F4F5FB 360rpx, #F4F5FB 100%);
}

/* 修复超屏：wxss 默认 content-box，width:100% + padding 会撑出屏幕 */
view, text, image, input, button, scroll-view, picker, textarea, navigator {
  box-sizing: border-box;
}

/* 通用工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-tertiary {
  color: var(--color-text-tertiary);
}

.text-success {
  color: var(--color-success);
}

.text-danger {
  color: var(--color-danger);
}

.text-money {
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

/* 金额字体 */
.money {
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

/* 卡片 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-card);
  padding: 28rpx;
  margin: 20rpx;
  box-shadow: var(--shadow-card);
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-separator);
  margin: 16rpx 0;
}
