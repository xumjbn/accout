.page { padding: 24rpx; min-height: 100vh; padding-bottom: 120rpx; }
.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }

.total-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.total-amounts {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.total-spent { font-size: 48rpx; font-weight: 700; font-variant-numeric: tabular-nums; }
.total-budget { font-size: 28rpx; color: #9CA3AF; }

.remaining-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
}

.over-warning {
  font-size: 24rpx;
  color: #EF4444;
  margin-top: 12rpx;
}

.empty-slot {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  color: #07C160;
  font-size: 28rpx;
}

.empty-hint {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
}

.cat-budget-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.cat-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cat-icon { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.cat-img { width: 30rpx; height: 30rpx; }
.cat-name { font-size: 28rpx; flex: 1; }
.cat-amount { font-size: 24rpx; color: #6B7280; font-variant-numeric: tabular-nums; }

.cat-over { font-size: 24rpx; color: #EF4444; margin-top: 8rpx; }

.add-btn {
  position: fixed;
  bottom: 48rpx;
  right: 48rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #07C160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
  z-index: 50;
}

/* 表单弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: flex-end;
  z-index: 200;
}

.modal-card {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  width: 100%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.form-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.form-label { font-size: 28rpx; color: #6B7280; }
.form-input { font-size: 32rpx; font-weight: 500; text-align: right; flex: 1; font-variant-numeric: tabular-nums; }
.form-picker { font-size: 28rpx; color: #111827; }

.form-footer {
  font-size: 22rpx;
  color: #9CA3AF;
  margin: 16rpx 0;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.modal-cancel, .modal-confirm {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-cancel { background: #F4F5FB; color: #6B7280; }
.modal-confirm { background: #07C160; color: #fff; }
