<!-- 预算管理 - 对应 iOS BudgetView -->
<view class="page">
  <!-- 总预算 -->
  <view class="section">
    <text class="section-title">本月总预算</text>
    <view wx:if="{{totalBudget}}" class="total-card" bindtap="editBudget">
      <view class="total-amounts">
        <text class="total-spent">¥{{totalSpent}}</text>
        <text class="total-budget">/ ¥{{totalAmount}}</text>
      </view>
      <budget-progress used="{{totalSpent}}" budget="{{totalAmount}}"></budget-progress>
      <view wx:if="{{isOver}}" class="over-warning">
        <text>⚠️ 已超支 ¥{{remaining}}</text>
      </view>
      <view wx:else class="remaining-row">
        <text>剩余 ¥{{remaining}}</text>
        <text>日均可用 ¥{{dailyAvailable}}</text>
      </view>
    </view>
    <view wx:else class="empty-slot" bindtap="showAddForm">
      <text>＋ 设置本月总预算</text>
    </view>
  </view>

  <!-- 分类预算 -->
  <view class="section">
    <text class="section-title">分类预算</text>
    <view wx:if="{{categoryBudgets.length === 0}}" class="empty-hint">
      还没有分类预算。点右上角 + 给某个分类单独设额度。
    </view>
    <view wx:for="{{categoryBudgets}}" wx:key="id" class="cat-budget-item"
      bindtap="editBudget" data-id="{{item.id}}">
      <view class="cat-header">
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.categoryRaw}}</text>
        <text class="cat-amount">¥{{item.spent}} / ¥{{item.amount}}</text>
      </view>
      <budget-progress used="{{item.spent}}" budget="{{item.amount}}"></budget-progress>
      <view wx:if="{{item.spent > item.amount}}" class="cat-over">
        <text>⚠️ 超支 ¥{{item.spent - item.amount}}</text>
      </view>
    </view>
  </view>

  <!-- 新建按钮 -->
  <view class="add-btn" bindtap="showAddForm">
    <text>＋</text>
  </view>

  <!-- 表单弹窗 -->
  <view wx:if="{{showForm}}" class="modal-mask" bindtap="saveForm">
    <view class="modal-card" catchtap="">
      <text class="modal-title">{{editingBudget ? '编辑预算' : '新建预算'}}</text>
      <view class="form-field">
        <text class="form-label">范围</text>
        <picker mode="selector" range="{{formCategories}}" value="{{formCategoryIndex}}" bindchange="onCategoryChange">
          <view class="form-picker">{{formCategory || '总预算（全部支出）'}}</view>
        </picker>
      </view>
      <view class="form-field">
        <text class="form-label">每月金额</text>
        <input class="form-input" placeholder="0" type="digit" value="{{formAmountText}}" bindinput="onAmountInput" />
      </view>
      <text class="form-footer">预算按自然月统计，每月 1 日进度自动清零，金额长期有效。</text>
      <view class="modal-btns">
        <view class="modal-cancel" bindtap="saveForm">取消</view>
        <view class="modal-confirm" bindtap="saveForm">保存</view>
      </view>
    </view>
  </view>
</view>
