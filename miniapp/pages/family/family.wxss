.page {
  padding: 24rpx;
}

/* 顶部渐变卡 */
.hero {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 44rpx 40rpx;
  border-radius: 28rpx;
  color: #fff;
  background:
    radial-gradient(circle at 85% 15%, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0) 42%),
    linear-gradient(135deg, #07C160 0%, #0ECF74 55%, #39D98A 100%);
  box-shadow: 0 12rpx 36rpx rgba(7, 193, 96, 0.35);
  margin-bottom: 24rpx;
}

.hero-label { font-size: 24rpx; opacity: 0.85; }
.hero-name { font-size: 48rpx; font-weight: 700; margin: 8rpx 0 12rpx; }
.hero-tip { font-size: 24rpx; opacity: 0.85; line-height: 1.6; }

.card { margin: 0 0 24rpx; }

/* 使用步骤 */
.how-row { display: flex; align-items: flex-start; gap: 16rpx; padding: 12rpx 0; }
.how-num {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #E7F7EE; color: #07C160;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.how-text { flex: 1; font-size: 26rpx; color: var(--color-text-secondary); line-height: 1.6; }

/* 本机统计 */
.stat-row { display: flex; align-items: center; gap: 16rpx; }
.member-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%; background: #E7F7EE;
  display: flex; align-items: center; justify-content: center;
}
.member-img { width: 32rpx; height: 32rpx; }
.stat-text { font-size: 28rpx; font-weight: 600; }

/* 合并结果 */
.result-title { display: block; font-size: 26rpx; font-weight: 600; margin-bottom: 8rpx; }
.result-text { font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.6; }

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #07C160 0%, #39D98A 100%);
  color: #fff; text-align: center; padding: 26rpx 0; border-radius: 999rpx;
  font-size: 30rpx; font-weight: 600;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.35);
  margin: 8rpx 0 20rpx;
}
.btn-secondary {
  background: #fff; color: #07C160; text-align: center; padding: 26rpx 0;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 600;
  border: 2rpx solid #07C160;
}

.foot-note {
  display: block; text-align: center; font-size: 22rpx;
  color: var(--color-text-tertiary); margin-top: 24rpx;
}
