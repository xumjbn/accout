.page { padding: 24rpx; background: #F3F4F6; min-height: 100vh; display: flex; flex-direction: column; }

.summary-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.summary-item { display: flex; justify-content: space-between; padding: 8rpx 0; }
.summary-label { font-size: 28rpx; color: #6B7280; }
.summary-value { font-size: 28rpx; font-weight: 600; }
.summary-value.dup { color: #F59E0B; }

.hint { font-size: 24rpx; color: #9CA3AF; margin-bottom: 24rpx; line-height: 1.6; }

.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }

.preview-list { flex: 1; background: #fff; border-radius: 16rpx; overflow: hidden; margin-bottom: 16rpx; }

.preview-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx; border-bottom: 1rpx solid #F3F4F6; }
.preview-row.duplicate { opacity: 0.35; }

.row-icon { font-size: 24rpx; flex-shrink: 0; }
.row-info { flex: 1; min-width: 0; }
.row-note { font-size: 28rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-date { font-size: 22rpx; color: #9CA3AF; }
.row-amount { font-size: 28rpx; font-weight: 500; font-variant-numeric: tabular-nums; }
.row-amount.income { color: #10B981; }

.more-hint { padding: 16rpx; text-align: center; font-size: 24rpx; color: #9CA3AF; }

.import-btn {
  background: #2563EB; color: #fff; text-align: center; padding: 24rpx;
  border-radius: 16rpx; font-size: 32rpx; font-weight: 600;
}
.import-btn.disabled { opacity: 0.4; }
