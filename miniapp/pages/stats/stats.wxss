.page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.period-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.switcher {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.arrow {
  font-size: 32rpx;
  color: #4E6EF5;
  padding: 8rpx 12rpx;
}

.arrow.disabled {
  color: #D1D5DB;
}

.period-title {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 190rpx;
  text-align: center;
}

/* 月/年切换 */
.dim-seg {
  display: flex;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  padding: 4rpx;
  box-shadow: 0 4rpx 14rpx rgba(38, 48, 92, 0.05);
}

.dim-opt {
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  color: #6B7280;
  border-radius: 999rpx;
}

.dim-opt.on {
  background: linear-gradient(135deg, #4E6EF5 0%, #7A5AF8 100%);
  color: #fff;
  font-weight: 600;
}

/* 汇总卡片 */
.totals-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.total-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(38, 48, 92, 0.04);
  min-width: 0;
}

.total-chip {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.total-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.total-label {
  font-size: 20rpx;
  color: #9CA3AF;
}

.total-value {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  margin-top: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.total-value.income { color: #10B981; }
.total-value.balance { color: #4E6EF5; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon { font-size: 64rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #6B7280; margin-top: 16rpx; }
.empty-desc { font-size: 26rpx; color: #9CA3AF; margin-top: 8rpx; }

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 图例 */
.pie-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 30%;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-name {
  font-size: 24rpx;
  color: #6B7280;
}

.legend-value {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-left: auto;
}

/* 柱状图 */
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 260rpx;
  gap: 8rpx;
  padding-top: 20rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  max-width: 48rpx;
  background: linear-gradient(to top, #4E6EF5, #BCC7FF);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s;
}

.bar-label {
  font-size: 18rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
  transform: rotate(-45deg);
  white-space: nowrap;
}

/* 排行 */
.rank-item {
  padding: 12rpx 0;
}

.rank-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.rank-dot {
  font-size: 22rpx;
}

.rank-name {
  font-size: 28rpx;
  flex: 1;
}

.rank-value {
  font-size: 26rpx;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}


/* 环形图 */
.donut-wrap {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.donut {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.donut-hole {
  position: absolute;
  inset: 26rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-k {
  font-size: 20rpx;
  color: #9CA3AF;
}

.donut-v {
  font-size: 28rpx;
  font-weight: 750;
  font-variant-numeric: tabular-nums;
}

.pie-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

/* 排行图标：淡染底 + emoji */
.rank-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}
