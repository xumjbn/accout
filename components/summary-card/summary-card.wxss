.summary-card {
  padding: 40rpx;
  background: linear-gradient(135deg, #3B82F6, #6366F1);
  border-radius: 24rpx;
  color: #fff;
}

.summary-label {
  font-size: 26rpx;
  opacity: 0.85;
}

.summary-value {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  margin: 8rpx 0 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
}

.summary-item-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.budget-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.budget-title-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.budget-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.budget-pct {
  font-size: 24rpx;
  opacity: 0.9;
}
