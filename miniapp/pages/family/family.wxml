<!-- 家庭共享（免费版）：账本文件微信群互传 + 智能合并 -->
<view class="page">
  <view class="hero">
    <text class="hero-label">家庭共享</text>
    <text class="hero-name">一家人记一本账</text>
    <text class="hero-tip">把账本发到家庭群，家人导入后自动合并；不用任何付费服务</text>
  </view>

  <view class="card how">
    <view class="how-row">
      <text class="how-num">1</text>
      <text class="how-text">点「分享账本给家人」，把文件发到家庭微信群</text>
    </view>
    <view class="how-row">
      <text class="how-num">2</text>
      <text class="how-text">家人打开语随记 → 本页点「从聊天记录导入」选中文件</text>
    </view>
    <view class="how-row">
      <text class="how-num">3</text>
      <text class="how-text">自动按账单智能合并（重复不会加两遍，删除也会同步）；想回传就反向再做一遍</text>
    </view>
  </view>

  <view class="card stat-row">
    <view class="member-avatar"><image class="member-img" src="{{icoPerson}}" mode="aspectFit" /></view>
    <text class="stat-text">本机账单 {{txCount}} 笔</text>
  </view>

  <view wx:if="{{lastResult}}" class="card result">
    <text class="result-title">上次合并结果</text>
    <text class="result-text">新增 {{lastResult.added}} 笔 · 更新 {{lastResult.updated}} 笔 · 删除同步 {{lastResult.removed}} 笔 · 合并后共 {{lastResult.total}} 笔</text>
  </view>

  <view class="btn-primary" bindtap="onShare">
    <text>分享账本给家人</text>
  </view>
  <view class="btn-secondary" bindtap="onImport">
    <text>从聊天记录导入家人账本</text>
  </view>

  <text class="foot-note">预算与资产归各自设备，不参与共享</text>
</view>
