.page { padding: 24rpx; min-height: 100vh; padding-bottom: 120rpx; }

.networth-card {
  position: relative;
  overflow: hidden;
  padding: 40rpx;
  background:
    radial-gradient(circle at 85% 12%, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0) 45%),
    linear-gradient(135deg, #F5A524 0%, #F97316 100%);
  border-radius: 28rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(245, 165, 36, 0.35);
}

.nw-label { font-size: 26rpx; opacity: 0.85; }
.nw-value { display: block; font-size: 64rpx; font-weight: 800; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; margin: 8rpx 0 16rpx; }
.nw-row { display: flex; justify-content: space-between; font-size: 24rpx; opacity: 0.85; }

.section { margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }

.account-item {
  background: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(38, 48, 92, 0.04);
}

.ac-row { display: flex; align-items: center; gap: 16rpx; }
.ac-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.ac-info { flex: 1; min-width: 0; }
.ac-name { font-size: 28rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ac-kind { font-size: 22rpx; color: #9CA3AF; }
.ac-right { text-align: right; }
.ac-balance { font-size: 30rpx; font-weight: 600; font-variant-numeric: tabular-nums; }
.ac-balance.liability { color: #EF4444; }
.ac-profit { font-size: 22rpx; color: #10B981; margin-top: 2rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 64rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #6B7280; margin-top: 16rpx; }
.empty-desc { font-size: 26rpx; color: #9CA3AF; margin-top: 8rpx; text-align: center; }

.add-btn {
  position: fixed; bottom: 48rpx; right: 48rpx; width: 96rpx; height: 96rpx;
  border-radius: 50%; background: #07C160; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3); z-index: 50;
}

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; z-index: 200; }
.modal-card { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 36rpx calc(40rpx + env(safe-area-inset-bottom)); width: 100%; max-height: 80vh; overflow-y: auto; }
.modal-title { display: block; font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; text-align: center; }

.kind-tabs { display: flex; background: #F0F2F9; border-radius: 999rpx; padding: 6rpx; margin-bottom: 32rpx; }
.kind-tab { flex: 1; text-align: center; padding: 16rpx; font-size: 28rpx; color: #6B7280; border-radius: 999rpx; }
.kind-tab.active { background: linear-gradient(135deg, #07C160 0%, #39D98A 100%); color: #fff; font-weight: 600; }

.form-field { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #ECEEF5; }
.form-label { font-size: 28rpx; color: #6B7280; flex-shrink: 0; margin-right: 24rpx; }
.form-input { flex: 1; text-align: right; font-size: 28rpx; font-variant-numeric: tabular-nums; }
.form-picker { font-size: 28rpx; color: #111827; }

.modal-btns { display: flex; gap: 24rpx; margin-top: 24rpx; }
.modal-cancel, .modal-confirm { flex: 1; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 30rpx; font-weight: 500; }
.modal-cancel { background: #F4F5FB; color: #6B7280; }
.modal-confirm { background: #07C160; color: #fff; }

.ac-img { width: 32rpx; height: 32rpx; }

.ac-loan { display: block; font-size: 20rpx; color: #9CA3AF; margin-top: 2rpx; }
