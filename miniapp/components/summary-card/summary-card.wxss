.summary-card {
  position: relative;
  overflow: hidden;
  padding: 40rpx;
  /* 品牌渐变 + 两团高光，做出玻璃光感 */
  background:
    radial-gradient(circle at 85% 15%, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0) 42%),
    radial-gradient(circle at 10% 90%, rgba(255, 214, 130, 0.18) 0%, rgba(255, 214, 130, 0) 45%),
    linear-gradient(135deg, #07C160 0%, #0ECF74 55%, #39D98A 100%);
  border-radius: 28rpx;
  color: #fff;
  box-shadow: 0 12rpx 36rpx rgba(7, 193, 96, 0.35);
}

.summary-label {
  font-size: 26rpx;
  opacity: 0.85;
}

.summary-value {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  font-variant-numeric: tabular-nums;
  margin: 8rpx 0 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
}

.summary-item-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.budget-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.budget-title-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.budget-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.budget-pct {
  font-size: 24rpx;
  opacity: 0.9;
}
