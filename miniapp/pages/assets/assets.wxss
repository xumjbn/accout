.page { padding: 24rpx; background: #F4F5FB; min-height: 100vh; padding-bottom: 120rpx; }

.networth-card {
  padding: 40rpx;
  background: linear-gradient(135deg, #14B8A6, #10B981);
  border-radius: 24rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.nw-label { font-size: 26rpx; opacity: 0.85; }
.nw-value { display: block; font-size: 56rpx; font-weight: 700; font-variant-numeric: tabular-nums; margin: 8rpx 0 16rpx; }
.nw-row { display: flex; justify-content: space-between; font-size: 24rpx; opacity: 0.85; }

.section { margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }

.account-item {
  background: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  border-radius: 20rpx;
}

.ac-row { display: flex; align-items: center; gap: 16rpx; }
.ac-icon { font-size: 28rpx; flex-shrink: 0; }
.ac-info { flex: 1; min-width: 0; }
.ac-name { font-size: 28rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ac-kind { font-size: 22rpx; color: #9CA3AF; }
.ac-right { text-align: right; }
.ac-balance { font-size: 30rpx; font-weight: 600; font-variant-numeric: tabular-nums; }
.ac-balance.liability { color: #EF4444; }
.ac-profit { font-size: 22rpx; color: #10B981; margin-top: 2rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 64rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #6B7280; margin-top: 16rpx; }
.empty-desc { font-size: 26rpx; color: #9CA3AF; margin-top: 8rpx; text-align: center; }

.add-btn {
  position: fixed; bottom: 48rpx; right: 48rpx; width: 96rpx; height: 96rpx;
  border-radius: 50%; background: #4E6EF5; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.3); z-index: 50;
}

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; z-index: 200; }
.modal-card { background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; width: 100%; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }

.kind-tabs { display: flex; background: #F4F5FB; border-radius: 20rpx; margin-bottom: 16rpx; overflow: hidden; }
.kind-tab { flex: 1; text-align: center; padding: 16rpx; font-size: 28rpx; color: #6B7280; }
.kind-tab.active { background: #4E6EF5; color: #fff; }

.form-field { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.form-label { font-size: 28rpx; color: #6B7280; flex-shrink: 0; margin-right: 24rpx; }
.form-input { flex: 1; text-align: right; font-size: 28rpx; font-variant-numeric: tabular-nums; }
.form-picker { font-size: 28rpx; color: #111827; }

.modal-btns { display: flex; gap: 24rpx; margin-top: 24rpx; }
.modal-cancel, .modal-confirm { flex: 1; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 30rpx; font-weight: 500; }
.modal-cancel { background: #F4F5FB; color: #6B7280; }
.modal-confirm { background: #4E6EF5; color: #fff; }
